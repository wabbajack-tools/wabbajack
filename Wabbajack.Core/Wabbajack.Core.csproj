<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework Condition=" '$(OS)' == 'Windows_NT'">net10.0-windows</TargetFramework>
        <TargetFramework Condition=" '$(OS)' != 'Windows_NT'">net10.0</TargetFramework>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <PackageLicenseExpression>GPL-3.0-or-later</PackageLicenseExpression>
        <VERSION Condition=" '$(VERSION)' == ''">4.0.0.0</VERSION>
        <Version>$(VERSION)</Version>
        <AssemblyName>wabbajack-cli</AssemblyName>
        <PublishTrimmed>true</PublishTrimmed>
        <TrimMode>linked</TrimMode>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
        <NoWarn>CS8600;CS8601;CS8618;CS8604</NoWarn>
        <JsonSerializerIsReflectionEnabledByDefault>true</JsonSerializerIsReflectionEnabledByDefault>
    </PropertyGroup>

    <!-- Platform constants -->
    <PropertyGroup Condition="'$(IsWindows)'=='true'">
        <DefineConstants>Windows;_WINDOWS</DefineConstants>
    </PropertyGroup>
    <PropertyGroup Condition="'$(IsOSX)'=='true'">
        <DefineConstants>OSX</DefineConstants>
    </PropertyGroup>
    <PropertyGroup Condition="'$(IsLinux)'=='true'">
        <DefineConstants>Linux</DefineConstants>
    </PropertyGroup>

    <ItemGroup>
        <!-- Core packages -->
        <PackageReference Include="BCnEncoder.Net.ImageSharp" />
        <PackageReference Include="DeviceId" />
        <PackageReference Include="F23.StringSimilarity" />
        <PackageReference Include="FluentFTP" />
        <PackageReference Include="FluentResults" />
        <PackageReference Include="GitInfo" />
        <PackageReference Include="HtmlAgilityPack" />
        <PackageReference Include="ini-parser-netstandard" />
        <PackageReference Include="JetBrains.Annotations" />
        <PackageReference Include="K4os.Compression.LZ4.Streams" />
        <PackageReference Include="Markdig" />
        <PackageReference Include="Microsoft.AspNetCore.Http.Extensions" />
        <PackageReference Include="Microsoft.Extensions.Configuration.Json" />
        <PackageReference Include="Microsoft.Extensions.DependencyInjection" />
        <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
        <PackageReference Include="Microsoft.Extensions.Hosting" />
        <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" />
        <PackageReference Include="Microsoft.Extensions.Http" />
        <PackageReference Include="Microsoft.Extensions.Logging" />
        <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
        <PackageReference Include="Microsoft.Toolkit.HighPerformance" />
        <PackageReference Include="Nettle" />
        <PackageReference Include="Newtonsoft.Json" />
        <PackageReference Include="NLog" />
        <PackageReference Include="NLog.Extensions.Logging" />
        <PackageReference Include="Octokit" />
        <PackageReference Include="OMODFramework" />
        <PackageReference Include="OneOf" />
        <PackageReference Include="Octopus.Octodiff" />
        <PackageReference Include="Reloaded.Memory" />
        <PackageReference Include="SharpZipLib" />
        <PackageReference Include="Shipwreck.Phash" />
        <PackageReference Include="shortid" />
        <PackageReference Include="SixLabors.ImageSharp" />
        <PackageReference Include="Stub.System.Data.SQLite.Core.NetStandard" />
        <PackageReference Include="Spectre.Console" />
        <PackageReference Include="System.CommandLine" />
        <PackageReference Include="System.CommandLine.NamingConventionBinder" />
        <PackageReference Include="System.Data.HashFunction.xxHash" />
        <PackageReference Include="System.Data.SQLite.Core" />
        <PackageReference Include="System.Reactive" />
        <PackageReference Include="TransparentValueObjects" />
        <PackageReference Include="TransparentValueObjects.Abstractions" />
        <PackageReference Include="ValveKeyValue" />
        <PackageReference Include="YamlDotNet" />

        <!-- Windows-only packages -->
        <PackageReference Include="Microsoft.Win32.Registry" Condition="'$(IsWindows)'=='true'" />

        <!-- GameFinder packages -->
        <PackageReference Include="GameFinder.StoreHandlers.Steam" />
        <PackageReference Include="GameFinder.StoreHandlers.GOG" />
        <PackageReference Include="GameFinder.Wine" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\Wabbajack.DTOs\Wabbajack.DTOs.csproj" />
    </ItemGroup>

    <ItemGroup>
      <None Update="CLI/VerbRegistration.tt">
        <Generator>TextTemplatingFileGenerator</Generator>
        <LastGenOutput>VerbRegistration.cs</LastGenOutput>
      </None>
    </ItemGroup>

    <ItemGroup>
      <Compile Update="CLI/VerbRegistration.cs">
        <AutoGen>True</AutoGen>
        <DesignTime>True</DesignTime>
        <DependentUpon>VerbRegistration.tt</DependentUpon>
      </Compile>
    </ItemGroup>

    <!-- Extractor tools -->
    <ItemGroup>
        <None Update="FileExtractor\Extractors\**\*">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </None>
        <None Update="Hashing\PHash\Tools\*">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </None>
    </ItemGroup>

    <!-- Embedded resources -->
    <ItemGroup>
        <EmbeddedResource Include="Reporting\Resources\*" />
        <EmbeddedResource Include="Server\HtmlReports\*" />
    </ItemGroup>

</Project>
