<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Wabbajack.App.Avalonia"
             x:Class="Wabbajack.App.Avalonia.App"
             RequestedThemeVariant="Dark">
    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Wabbajack.Avalonia/Styles/AppStyles.axaml" />
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <!-- ── Font families ──────────────────────────────────── -->
            <FontFamily x:Key="MontserratFont">avares://Wabbajack.Avalonia/Assets/Fonts#Montserrat</FontFamily>
            <FontFamily x:Key="OpenSansFont">avares://Wabbajack.Avalonia/Assets/Fonts#Open Sans</FontFamily>

            <!-- ── FluentTheme accent color overrides ─────────────── -->
            <Color x:Key="SystemAccentColor">#a855f7</Color>
            <Color x:Key="SystemAccentColorDark1">#9333ea</Color>
            <Color x:Key="SystemAccentColorDark2">#7e22ce</Color>
            <Color x:Key="SystemAccentColorLight1">#b86bff</Color>
            <Color x:Key="SystemAccentColorLight2">#c084fc</Color>
            <SolidColorBrush x:Key="SystemControlHighlightAccentBrush" Color="#a855f7" />

            <!-- ── FluentTheme button overrides (kill the grey) ───── -->
            <SolidColorBrush x:Key="ButtonBackground" Color="Transparent" />
            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#1Aa855f7" />
            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#26a855f7" />
            <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="#0D252542" />
            <SolidColorBrush x:Key="ButtonForeground" Color="#f8fafc" />
            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#ffffff" />
            <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#f8fafc" />
            <SolidColorBrush x:Key="ButtonForegroundDisabled" Color="#44f8fafc" />
            <SolidColorBrush x:Key="ButtonBorderBrush" Color="#33a855f7" />
            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#55a855f7" />
            <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#66a855f7" />
            <SolidColorBrush x:Key="ButtonBorderBrushDisabled" Color="#1Aa855f7" />

            <!-- ── FluentTheme control surface overrides ──────────── -->
            <SolidColorBrush x:Key="TextControlBackground" Color="#252542" />
            <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#2a2a4a" />
            <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#252542" />
            <SolidColorBrush x:Key="TextControlBorderBrush" Color="#33a855f7" />
            <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#44a855f7" />
            <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#66a855f7" />
            <SolidColorBrush x:Key="TextControlForeground" Color="#f8fafc" />
            <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#64748b" />

            <SolidColorBrush x:Key="ComboBoxBackground" Color="#252542" />
            <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver" Color="#2a2a4a" />
            <SolidColorBrush x:Key="ComboBoxBorderBrush" Color="#33a855f7" />
            <SolidColorBrush x:Key="ComboBoxBorderBrushPointerOver" Color="#44a855f7" />

            <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="#33a855f7" />
            <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="#44a855f7" />
            <SolidColorBrush x:Key="ListViewItemForegroundSelected" Color="#f8fafc" />

            <SolidColorBrush x:Key="TabViewItemHeaderBackgroundSelected" Color="#33a855f7" />
            <SolidColorBrush x:Key="TabViewItemHeaderBackground" Color="Transparent" />
            <SolidColorBrush x:Key="TabViewItemHeaderBackgroundPointerOver" Color="#1Aa855f7" />

            <!-- ── Darkwave colour palette ────────────────────────── -->
            <Color x:Key="AppBackground">#0a0a0f</Color>
            <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackground}" />

            <Color x:Key="BackgroundLight">#12121a</Color>
            <SolidColorBrush x:Key="BackgroundLightBrush" Color="{StaticResource BackgroundLight}" />

            <Color x:Key="SurfaceColor">#1a1a2e</Color>
            <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />

            <Color x:Key="SurfaceLightColor">#252542</Color>
            <SolidColorBrush x:Key="SurfaceLightBrush" Color="{StaticResource SurfaceLightColor}" />

            <Color x:Key="PrimaryColor">#a855f7</Color>
            <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />

            <Color x:Key="SecondaryColor">#ec4899</Color>
            <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}" />

            <Color x:Key="TertiaryColor">#22d3ee</Color>
            <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource TertiaryColor}" />

            <SolidColorBrush x:Key="ForegroundBrush" Color="#f8fafc" />
            <SolidColorBrush x:Key="ForegroundSecondaryBrush" Color="#94a3b8" />
            <SolidColorBrush x:Key="ForegroundMutedBrush" Color="#64748b" />

            <SolidColorBrush x:Key="NSFWBrush" Color="#ef4444" />
            <SolidColorBrush x:Key="UnavailableBrush" Color="#ef4444" />
            <SolidColorBrush x:Key="UnavailableDarkBrush" Color="#88ef4444" />

            <SolidColorBrush x:Key="SuccessBrush" Color="#10b981" />
            <SolidColorBrush x:Key="WarningBrush" Color="#f59e0b" />

            <SolidColorBrush x:Key="ComplementaryBackgroundBrush" Color="{StaticResource SurfaceColor}" />
            <SolidColorBrush x:Key="ComplementaryPrimary08Brush" Color="#14a855f7" />
            <SolidColorBrush x:Key="DarkSecondaryBrush" Color="#252542" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
