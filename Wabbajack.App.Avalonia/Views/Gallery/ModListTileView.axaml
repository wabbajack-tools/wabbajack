<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ic="using:FluentIcons.Avalonia"
             x:Class="Wabbajack.App.Avalonia.Views.Gallery.ModListTileView"
             d:DesignHeight="268" d:DesignWidth="476"
             mc:Ignorable="d">

    <UserControl.Styles>
        <!-- Tile root: hover glow + scale + border brightening -->
        <Style Selector="Border.TileRoot">
            <Setter Property="BoxShadow" Value="0 4 16 0 #00000040" />
            <Setter Property="BorderBrush" Value="#33a855f7" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="RenderTransformOrigin" Value="50%,50%" />
            <Setter Property="Transitions">
                <Transitions>
                    <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.25" />
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.25" />
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.25" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.TileRoot:pointerover">
            <Setter Property="BoxShadow" Value="0 8 32 0 #55a855f7" />
            <Setter Property="RenderTransform" Value="scaleX(1.02) scaleY(1.02)" />
            <Setter Property="BorderBrush" Value="#66a855f7" />
        </Style>

        <!-- Animate bottom gradient opacity on pointer-over of the tile border -->
        <Style Selector="Border.TileRoot Rectangle.BottomGradient">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.2" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.TileRoot:pointerover Rectangle.BottomGradient">
            <Setter Property="Opacity" Value="0.75" />
        </Style>

        <!-- Top shimmer on hover -->
        <Style Selector="Border.TileRoot Rectangle.TopShimmer">
            <Setter Property="Opacity" Value="0.05" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.2" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.TileRoot:pointerover Rectangle.TopShimmer">
            <Setter Property="Opacity" Value="0.3" />
        </Style>

        <!-- Game name: only on hover -->
        <Style Selector="Border.TileRoot Border.GameNamePill">
            <Setter Property="IsVisible" Value="False" />
        </Style>
        <Style Selector="Border.TileRoot:pointerover Border.GameNamePill">
            <Setter Property="IsVisible" Value="True" />
        </Style>

        <!-- Broken overlay: only on hover -->
        <Style Selector="Border.TileRoot Border.BrokenOverlay">
            <Setter Property="IsVisible" Value="False" />
        </Style>
        <Style Selector="Border.TileRoot:pointerover Border.BrokenOverlay">
            <Setter Property="IsVisible" Value="True" />
        </Style>
    </UserControl.Styles>

    <!-- Card button — chromeless wrapper, all visuals on the inner Border -->
    <Button x:Name="ModlistButton"
            Classes="chromeless">

        <Border x:Name="TileRoot"
                Classes="TileRoot"
                Margin="8,0,8,16"
                CornerRadius="8"
                ClipToBounds="True"
                Background="#151528"
                Width="476" Height="268">

            <Grid Width="476" Height="268" ClipToBounds="True">

                <!-- Background image -->
                <Image x:Name="ModlistImage"
                       Stretch="UniformToFill" />

                <!-- Loading spinner while image downloads -->
                <ProgressBar IsIndeterminate="True"
                             IsVisible="{Binding LoadingImage}"
                             VerticalAlignment="Center"
                             HorizontalAlignment="Center"
                             Width="60" Height="4" />

                <!-- Top shimmer (hover effect) -->
                <Rectangle Classes="TopShimmer"
                           Height="120"
                           Margin="-80,-95,-80,0"
                           VerticalAlignment="Top"
                           Fill="White">
                    <Rectangle.Effect>
                        <BlurEffect Radius="100" />
                    </Rectangle.Effect>
                </Rectangle>

                <!-- Bottom gradient backdrop (animated on hover when ImageContainsTitle=true) -->
                <Rectangle Classes="BottomGradient"
                           Height="120"
                           Margin="-80,0,-80,-75"
                           VerticalAlignment="Bottom"
                           Fill="Black"
                           IsVisible="{Binding ImageContainsTitle}">
                    <Rectangle.Effect>
                        <BlurEffect Radius="100" />
                    </Rectangle.Effect>
                </Rectangle>

                <!-- Always-visible bottom gradient (when image does NOT contain title) -->
                <Rectangle Height="120"
                           Margin="-80,0,-80,-75"
                           VerticalAlignment="Bottom"
                           Fill="Black"
                           Opacity="0.75"
                           IsVisible="{Binding !ImageContainsTitle}">
                    <Rectangle.Effect>
                        <BlurEffect Radius="100" />
                    </Rectangle.Effect>
                </Rectangle>

                <!-- Info overlay: title / author / sizes -->
                <Grid Margin="10,0,10,10"
                      VerticalAlignment="Bottom"
                      ZIndex="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MaxWidth="380" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Grid.Row="1"
                               Text="{Binding Metadata.Title}"
                               FontFamily="{StaticResource MontserratFont}"
                               FontWeight="Bold" FontSize="22"
                               TextWrapping="Wrap" MaxWidth="380"
                               Foreground="White"
                               Margin="0,0,0,2" />

                    <StackPanel Grid.Column="0" Grid.Row="2"
                                Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="by" Opacity="0.6" FontSize="12"
                                   Foreground="White" />
                        <TextBlock Text="{Binding Metadata.Author}" FontSize="12"
                                   Foreground="White" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Grid.Row="2"
                                Orientation="Horizontal" Spacing="4"
                                VerticalAlignment="Bottom">
                        <ic:SymbolIcon Symbol="ArrowDownload"
                                       FontSize="12" Opacity="0.6"
                                       Foreground="White"
                                       VerticalAlignment="Center" />
                        <TextBlock Text="{Binding DownloadSizeText}"
                                   FontSize="12" Opacity="0.6"
                                   Foreground="White"
                                   VerticalAlignment="Center" />
                        <ic:SymbolIcon Symbol="Games"
                                       FontSize="12" Opacity="0.6"
                                       Foreground="White"
                                       Margin="6,0,0,0"
                                       VerticalAlignment="Center" />
                        <TextBlock Text="{Binding InstallSizeText}"
                                   FontSize="12" Opacity="0.6"
                                   Foreground="White"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>

                <!-- Top-left: game icon + name -->
                <Grid Margin="8,8,0,0"
                      VerticalAlignment="Top" HorizontalAlignment="Left"
                      ZIndex="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="26" Height="26"
                            CornerRadius="6"
                            Background="#252542" />

                    <!-- Game name pill — only visible on hover via style -->
                    <Border Grid.Column="2"
                            Classes="GameNamePill"
                            Background="#CC0a0a0f"
                            CornerRadius="4"
                            Padding="8,2">
                        <TextBlock Text="{Binding GameMetaData.HumanFriendlyGameName}"
                                   FontSize="11" Foreground="White" />
                    </Border>
                </Grid>

                <!-- NSFW badge -->
                <Border HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,8,8,0"
                        ZIndex="2"
                        IsVisible="{Binding Metadata.NSFW}"
                        Background="{StaticResource NSFWBrush}"
                        CornerRadius="4"
                        Padding="8,2">
                    <TextBlock Text="NSFW" FontSize="11" FontWeight="SemiBold"
                               Foreground="White" />
                </Border>

                <!-- Unavailable badge -->
                <Border HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,36,8,0"
                        ZIndex="2"
                        IsVisible="{Binding IsBroken}"
                        Background="{StaticResource UnavailableBrush}"
                        CornerRadius="4"
                        Padding="8,2">
                    <TextBlock Text="Unavailable" FontSize="11" FontWeight="SemiBold"
                               Foreground="White" />
                </Border>

                <!-- Broken overlay (dark tint + message on hover) -->
                <Border Classes="BrokenOverlay"
                        IsVisible="{Binding IsBroken}"
                        Background="{StaticResource UnavailableDarkBrush}"
                        ZIndex="3">
                    <TextBlock Margin="16"
                               FontSize="14"
                               TextWrapping="Wrap"
                               Foreground="White"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Text="A game or mod update has made this list unavailable. Contact the author(s) for more information." />
                </Border>

            </Grid>
        </Border>
    </Button>
</UserControl>
