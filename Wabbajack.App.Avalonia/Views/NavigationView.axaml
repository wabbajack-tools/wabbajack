<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ic="using:FluentIcons.Avalonia"
             x:Class="Wabbajack.App.Avalonia.Views.NavigationView"
             mc:Ignorable="d">
    <Border BorderThickness="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Home -->
            <Button x:Name="HomeButton" Grid.Row="0" Height="95" Margin="8,0,8,0"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <ic:SymbolIcon Grid.Row="0" Symbol="Home" FontSize="36"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <TextBlock Grid.Row="1" FontSize="13" HorizontalAlignment="Center"
                               VerticalAlignment="Center" Margin="0,8,0,0" Text="Home" />
                </Grid>
            </Button>

            <!-- Browse lists -->
            <Button x:Name="BrowseButton" Grid.Row="2" Height="95" Margin="8,0,8,0"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <ic:SymbolIcon Grid.Row="0" Symbol="CloudArrowDown" FontSize="36"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <TextBlock Grid.Row="1" FontSize="13" HorizontalAlignment="Center"
                               VerticalAlignment="Center" Margin="0,8,0,0" Text="Browse lists" />
                </Grid>
            </Button>

            <!-- Create a list -->
            <Button x:Name="CreateButton" Grid.Row="4" Height="95" Margin="8,0,8,0"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <ic:SymbolIcon Grid.Row="0" Symbol="Toolbox" FontSize="36"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <TextBlock Grid.Row="1" FontSize="13" HorizontalAlignment="Center"
                               VerticalAlignment="Center" Margin="0,8,0,0" Text="Create a list" />
                </Grid>
            </Button>

            <!-- Settings (disabled) -->
            <Button Grid.Row="6" Height="95" Margin="8,0,8,0" IsEnabled="False"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <ic:SymbolIcon Grid.Row="0" Symbol="Settings" FontSize="36"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <TextBlock Grid.Row="1" FontSize="13" HorizontalAlignment="Center"
                               VerticalAlignment="Center" Margin="0,8,0,0" Text="Settings" />
                </Grid>
            </Button>

            <!-- Version -->
            <TextBlock x:Name="VersionText" Grid.Row="7" FontSize="12"
                       HorizontalAlignment="Center" Margin="0,10,0,10"
                       Foreground="{StaticResource ForegroundBrush}" Opacity="0.66" />
        </Grid>
    </Border>
</UserControl>
