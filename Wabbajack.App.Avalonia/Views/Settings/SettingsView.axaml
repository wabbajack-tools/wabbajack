<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ic="using:FluentIcons.Avalonia"
             xmlns:vm="using:Wabbajack.App.Avalonia.ViewModels.Settings"
             x:Class="Wabbajack.App.Avalonia.Views.Settings.SettingsView"
             mc:Ignorable="d">

    <TabControl Margin="8">

        <!-- ══ Performance tab ════════════════════════════════════════════ -->
        <TabItem Header="Performance">
            <ScrollViewer Padding="0,8,0,0">
                <StackPanel Spacing="0">

                    <TextBlock Text="Resource Limits"
                               FontSize="16" FontWeight="SemiBold"
                               FontFamily="{StaticResource MontserratFont}"
                               Margin="4,0,0,12" />

                    <ItemsControl x:Name="ResourceSettingsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:ResourceSettingVM">
                                <Border Margin="0,0,0,8"
                                        Padding="16,12"
                                        CornerRadius="8"
                                        Background="{StaticResource SurfaceBrush}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="8"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="8"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Resource name -->
                                        <TextBlock Grid.Row="0"
                                                   Text="{Binding Name}"
                                                   FontSize="14" FontWeight="SemiBold" />

                                        <!-- Max Tasks -->
                                        <Grid Grid.Row="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="180"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="48"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="Max concurrent tasks"
                                                       VerticalAlignment="Center"
                                                       Opacity="0.8" />
                                            <Slider Grid.Column="1"
                                                    x:Name="MaxTasksSlider"
                                                    Minimum="1" Maximum="64"
                                                    TickFrequency="1"
                                                    IsSnapToTickEnabled="True"
                                                    Value="{Binding MaxTasks}"
                                                    Margin="12,0" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding MaxTasks}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right" />
                                        </Grid>

                                        <!-- Max Throughput -->
                                        <Grid Grid.Row="4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="180"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="Max throughput (MB/s)"
                                                       VerticalAlignment="Center"
                                                       Opacity="0.8" />
                                            <Slider Grid.Column="1"
                                                    Minimum="0" Maximum="1000"
                                                    TickFrequency="10"
                                                    IsSnapToTickEnabled="True"
                                                    Value="{Binding MaxThroughputMB}"
                                                    Margin="12,0" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding ThroughputLabel}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right" />
                                        </Grid>

                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Set to 0 MB/s for unlimited throughput."
                               Opacity="0.5" FontSize="12" Margin="4,4,0,0" />
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <!-- ══ About tab ══════════════════════════════════════════════════ -->
        <TabItem Header="About">
            <ScrollViewer Padding="0,8,0,0">
                <StackPanel HorizontalAlignment="Center" MaxWidth="480" Spacing="16">

                    <!-- Logo / title -->
                    <StackPanel HorizontalAlignment="Center" Spacing="4">
                        <TextBlock Text="Wabbajack"
                                   FontSize="36" FontWeight="Bold"
                                   FontFamily="{StaticResource MontserratFont}"
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource PrimaryBrush}" />
                        <TextBlock x:Name="VersionText"
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   Opacity="0.7" />
                    </StackPanel>

                    <Separator Opacity="0.3" />

                    <!-- Description -->
                    <TextBlock TextWrapping="Wrap" TextAlignment="Center" Opacity="0.8"
                               Text="Wabbajack is an automated modlist installer that makes it easy to install complex mod setups in minutes." />

                    <!-- Buttons -->
                    <StackPanel Spacing="8">
                        <Button x:Name="OpenGitHubButton"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Height="44">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <ic:SymbolIcon Symbol="Open" />
                                <TextBlock Text="View on GitHub" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button x:Name="OpenLogFolderButton"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Height="44">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <ic:SymbolIcon Symbol="FolderOpen" />
                                <TextBlock Text="Open Log Folder" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <Separator Opacity="0.3" />

                    <TextBlock TextWrapping="Wrap" TextAlignment="Center" Opacity="0.5" FontSize="12"
                               Text="Wabbajack is open-source software. Visit the GitHub repository to report issues, contribute, or browse the source code." />

                </StackPanel>
            </ScrollViewer>
        </TabItem>

    </TabControl>
</UserControl>
