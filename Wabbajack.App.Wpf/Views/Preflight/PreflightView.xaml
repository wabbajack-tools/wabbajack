<rxui:ReactiveUserControl
    x:Class="Wabbajack.Views.Preflight.PreflightView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:rxui="http://reactiveui.net"
    xmlns:local="clr-namespace:Wabbajack"
    xmlns:preflight="clr-namespace:Wabbajack.Preflight"
    xmlns:ic="clr-namespace:FluentIcons.Wpf;assembly=FluentIcons.Wpf"
    d:DataContext="{d:DesignInstance preflight:PreflightViewModel}"
    x:TypeArguments="preflight:PreflightViewModel"
    mc:Ignorable="d"
    d:DesignHeight="600"
    d:DesignWidth="800">

    <UserControl.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="24">

            <!-- Header: Modlist name + View Readme -->
            <DockPanel Margin="0,0,0,16">
                <Button x:Name="ViewReadmeButton"
                        DockPanel.Dock="Right"
                        Content="View Readme"
                        Padding="12,6"
                        VerticalAlignment="Center" />
                <TextBlock x:Name="ModlistNameText"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center" />
            </DockPanel>

            <!-- Path Pickers -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="Install Location"
                           Foreground="#aaa"
                           FontSize="13"
                           Margin="0,0,0,4" />
                <local:FilePicker x:Name="InstallLocationPicker" Margin="0,0,0,12" />

                <TextBlock Text="Download Location"
                           Foreground="#aaa"
                           FontSize="13"
                           Margin="0,0,0,4" />
                <local:FilePicker x:Name="DownloadLocationPicker" />
            </StackPanel>

            <!-- Summary Bar -->
            <Border x:Name="SummaryBar"
                    CornerRadius="6"
                    Padding="16,10"
                    Margin="0,0,0,16">
                <TextBlock x:Name="SummaryText"
                           FontSize="15"
                           FontWeight="SemiBold" />
            </Border>

            <!-- Failed Checks List -->
            <ItemsControl x:Name="FailedChecksList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type preflight:IPreflightCheck}">
                        <Border Background="#1e1118"
                                BorderBrush="#7f1d1d"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="16"
                                Margin="0,0,0,8">
                            <StackPanel>
                                <!-- Title row with action button -->
                                <DockPanel>
                                    <Button DockPanel.Dock="Right"
                                            Content="{Binding ActionLabel}"
                                            Command="{Binding ActionCommand}"
                                            Padding="10,4"
                                            VerticalAlignment="Center">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ActionCommand}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <TextBlock Foreground="#f87171"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center">
                                        <Run Text="&#x2717; " /><Run Text="{Binding Title, Mode=OneWay}" />
                                    </TextBlock>
                                </DockPanel>

                                <!-- Failure message -->
                                <TextBlock Text="{Binding FailureMessage}"
                                           Foreground="#ccc"
                                           FontSize="13"
                                           TextWrapping="Wrap"
                                           Margin="0,6,0,0" />

                                <!-- SubItems list -->
                                <ItemsControl ItemsSource="{Binding SubItems}"
                                              Margin="0,8,0,0">
                                    <ItemsControl.Style>
                                        <Style TargetType="ItemsControl">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SubItems}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ItemsControl.Style>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type preflight:PreflightSubItem}">
                                            <Border Background="#2a1520"
                                                    CornerRadius="4"
                                                    Padding="12,8"
                                                    Margin="0,0,0,4">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <!-- Name -->
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding Name}"
                                                               Foreground="White"
                                                               FontSize="13"
                                                               TextTrimming="CharacterEllipsis"
                                                               VerticalAlignment="Center" />

                                                    <!-- Size -->
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding SizeText}"
                                                               Foreground="#999"
                                                               FontSize="12"
                                                               Margin="12,0"
                                                               VerticalAlignment="Center" />

                                                    <!-- Action Button -->
                                                    <Button Grid.Column="2"
                                                            Content="{Binding ActionLabel}"
                                                            Command="{Binding ActionCommand}"
                                                            Padding="8,3"
                                                            FontSize="12"
                                                            VerticalAlignment="Center">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ActionCommand}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>

                                                    <!-- Status / Progress row -->
                                                    <StackPanel Grid.Row="1" Grid.ColumnSpan="3"
                                                                Margin="0,4,0,0">
                                                        <StackPanel.Style>
                                                            <Style TargetType="StackPanel">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding StatusText}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </StackPanel.Style>
                                                        <TextBlock Text="{Binding StatusText}"
                                                                   Foreground="#aaa"
                                                                   FontSize="11" />
                                                        <ProgressBar Value="{Binding Progress}"
                                                                     Minimum="0" Maximum="1"
                                                                     Height="4"
                                                                     Margin="0,3,0,0">
                                                            <ProgressBar.Style>
                                                                <Style TargetType="ProgressBar">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Progress}" Value="{x:Null}">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ProgressBar.Style>
                                                        </ProgressBar>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Install Button -->
            <Button x:Name="InstallButton"
                    Content="Install"
                    HorizontalAlignment="Right"
                    Padding="24,10"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Margin="0,16,0,0" />

        </StackPanel>
    </ScrollViewer>
</rxui:ReactiveUserControl>
