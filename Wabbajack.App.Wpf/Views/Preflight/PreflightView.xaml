<rxui:ReactiveUserControl
    x:Class="Wabbajack.Views.Preflight.PreflightView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:rxui="http://reactiveui.net"
    xmlns:local="clr-namespace:Wabbajack"
    xmlns:preflight="clr-namespace:Wabbajack.Preflight"
    xmlns:ic="clr-namespace:FluentIcons.Wpf;assembly=FluentIcons.Wpf"
    d:DataContext="{d:DesignInstance preflight:PreflightViewModel}"
    x:TypeArguments="preflight:PreflightViewModel"
    mc:Ignorable="d"
    d:DesignHeight="600"
    d:DesignWidth="800">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="24">

            <!-- Header: Modlist name + View Readme -->
            <DockPanel Margin="0,0,0,16">
                <local:WJButton x:Name="ViewReadmeButton"
                                DockPanel.Dock="Right"
                                ButtonStyle="Mono"
                                Text="View Readme"
                                Icon="Document"
                                VerticalAlignment="Center" />
                <TextBlock x:Name="ModlistNameText"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center" />
            </DockPanel>

            <!-- Path Pickers -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="Install Location"
                           Foreground="#aaa"
                           FontSize="13"
                           Margin="0,0,0,4" />
                <local:FilePicker x:Name="InstallLocationPicker" Icon="Folder" Margin="0,0,0,12" />

                <TextBlock Text="Download Location"
                           Foreground="#aaa"
                           FontSize="13"
                           Margin="0,0,0,4" />
                <local:FilePicker x:Name="DownloadLocationPicker" Icon="Folder" />
            </StackPanel>

            <!-- Summary Bar -->
            <Border x:Name="SummaryBar"
                    CornerRadius="6"
                    Padding="16,10"
                    Margin="0,0,0,16">
                <TextBlock x:Name="SummaryText"
                           FontSize="15"
                           FontWeight="SemiBold" />
            </Border>

            <!-- Visible Checks List (failed + info) -->
            <ItemsControl x:Name="FailedChecksList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type preflight:IPreflightCheck}">
                        <Border CornerRadius="6"
                                Padding="16"
                                Margin="0,0,0,8">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#1e1118" />
                                    <Setter Property="BorderBrush" Value="#7f1d1d" />
                                    <Setter Property="BorderThickness" Value="1" />
                                    <Style.Triggers>
                                        <!-- Info cards get a neutral/blue style instead of red -->
                                        <DataTrigger Binding="{Binding Status}" Value="{x:Static preflight:PreflightCheckStatus.Info}">
                                            <Setter Property="Background" Value="#111827" />
                                            <Setter Property="BorderBrush" Value="#1e3a5f" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <!-- Title row with action button -->
                                <DockPanel>
                                    <local:WJButton DockPanel.Dock="Right"
                                                    Text="{Binding ActionLabel}"
                                                    Command="{Binding ActionCommand}"
                                                    ButtonStyle="Mono"
                                                    Icon="ArrowDownload"
                                                    VerticalAlignment="Center">
                                        <local:WJButton.Style>
                                            <Style TargetType="local:WJButton">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ActionCommand}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </local:WJButton.Style>
                                    </local:WJButton>
                                    <TextBlock FontSize="15"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#f87171" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="{x:Static preflight:PreflightCheckStatus.Info}">
                                                        <Setter Property="Foreground" Value="#60a5fa" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                        <Run x:Name="CheckIcon" Text="&#x2717; " /><Run Text="{Binding Title, Mode=OneWay}" />
                                    </TextBlock>
                                </DockPanel>

                                <!-- Failure/info message -->
                                <TextBlock Text="{Binding FailureMessage}"
                                           Foreground="#ccc"
                                           FontSize="13"
                                           TextWrapping="Wrap"
                                           Margin="0,6,0,0" />

                                <!-- SubItems list -->
                                <ItemsControl ItemsSource="{Binding SubItems}"
                                              Margin="0,8,0,0">
                                    <ItemsControl.Style>
                                        <Style TargetType="ItemsControl">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SubItems}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ItemsControl.Style>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type preflight:PreflightSubItem}">
                                            <Border Background="{StaticResource ComplementaryPrimary08Brush}"
                                                    CornerRadius="4"
                                                    Padding="12,8"
                                                    Margin="0,0,0,4">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <!-- Name -->
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding Name}"
                                                               Foreground="White"
                                                               FontSize="13"
                                                               TextTrimming="CharacterEllipsis"
                                                               VerticalAlignment="Center" />

                                                    <!-- Size -->
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding SizeText}"
                                                               Foreground="{StaticResource Transparent66ForegroundBrush}"
                                                               FontSize="12"
                                                               Margin="12,0"
                                                               VerticalAlignment="Center" />

                                                    <!-- Action Button -->
                                                    <local:WJButton Grid.Column="2"
                                                                    Text="{Binding ActionLabel}"
                                                                    Command="{Binding ActionCommand}"
                                                                    ButtonStyle="SemiTransparent"
                                                                    Icon="Open"
                                                                    IconSize="16"
                                                                    VerticalAlignment="Center">
                                                        <local:WJButton.Style>
                                                            <Style TargetType="local:WJButton">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ActionCommand}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </local:WJButton.Style>
                                                    </local:WJButton>

                                                    <!-- Status / Progress row -->
                                                    <StackPanel Grid.Row="1" Grid.ColumnSpan="3"
                                                                Margin="0,4,0,0">
                                                        <StackPanel.Style>
                                                            <Style TargetType="StackPanel">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding StatusText}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </StackPanel.Style>
                                                        <TextBlock Text="{Binding StatusText}"
                                                                   Foreground="{StaticResource Transparent66ForegroundBrush}"
                                                                   FontSize="11" />
                                                        <ProgressBar Value="{Binding Progress}"
                                                                     Minimum="0" Maximum="1"
                                                                     Height="4"
                                                                     Margin="0,3,0,0">
                                                            <ProgressBar.Style>
                                                                <Style TargetType="ProgressBar">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Progress}" Value="{x:Null}">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ProgressBar.Style>
                                                        </ProgressBar>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Install Button -->
            <local:WJButton x:Name="InstallButton"
                            Text="Install"
                            Icon="DesktopArrowDown"
                            ButtonStyle="Color"
                            HorizontalAlignment="Right"
                            Margin="0,16,0,0" />

        </StackPanel>
    </ScrollViewer>
</rxui:ReactiveUserControl>
